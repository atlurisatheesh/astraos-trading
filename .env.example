# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://astraos:astraos_dev@localhost:5432/astraos
DATABASE_URL_SYNC=postgresql://astraos:astraos_dev@localhost:5432/astraos

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM ──────────────────────────────────────────────
GEMINI_API_KEY=your_free_api_key_from_aistudio_google_dev
LLM_PROVIDER=gemini_free
OPENAI_API_KEY=

# ── Market Data ──────────────────────────────────────
MARKET_DATA_PROVIDER=yfinance

# ── Angel One SmartAPI (FREE real-time NSE data) ────
# Sign up at smartapi.angelone.in (free with demat account)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ── Zerodha Kite Connect (Rs 2000/month) ────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ── Broker ───────────────────────────────────────────
BROKER_PROVIDER=paper

# ── Broker Key Encryption ───────────────────────────
# Independent key for encrypting broker API keys at rest (32+ chars)
BROKER_ENCRYPTION_KEY=

# ── News ─────────────────────────────────────────────
NEWS_PROVIDER=rss_gdelt

# ── Alerts (Telegram) ───────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Alerts (Email / SMTP) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_NAME=AstraOS
CORS_ORIGINS=http://localhost:3000
